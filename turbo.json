{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "outputs": ["dist/**", ".expo/**", "out/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["build"]
    },
    "lint": {},
    "generator#build": {
      "dependsOn": ["^build"],
      "outputs": ["out/**"]
    },
    "generator#typecheck": {
      "dependsOn": ["^typecheck"]
    }
  }
}